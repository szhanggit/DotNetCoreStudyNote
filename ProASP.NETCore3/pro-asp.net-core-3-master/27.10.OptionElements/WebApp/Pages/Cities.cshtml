@page
@model WebApp.Pages.CitiesModel

<div class="m-2">
    <table class="table table-sm table-striped table-bordered">
        <thead>
            <tr bg-color="info" text-color="white">
                <th colspan="3">Product Summary</th>
            </tr>
        </thead>
        <tbody>
            @foreach (City c in Model.Data.Cities)
            {
                <tr>
                    <td>@c.Name</td>
                    <td>@c.Country</td>
                    <td>@c.Population</td>
                </tr>
            }
        </tbody>
    </table>
</div>
